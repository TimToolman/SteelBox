{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm --prefix apps/web install && npm --prefix apps/web run build",
  "outputDirectory": "apps/web/dist",
  "installCommand": "npm install --no-audit --no-fund",
  "build": {
    "env": {
      "VITE_BASE": "/",
      "VITE_SITE_ORIGIN": "https://www.mvpcontainers.com",
      "VITE_API_URL": "https://steelbox-production.up.railway.app"
    }
  },
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "mvpcontainers.com" }],
      "destination": "https://www.mvpcontainers.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/app.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/og/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    }
  ]
}
